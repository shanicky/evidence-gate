{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecisionAssuranceJudgeVerdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gate_required",
    "gate_reason",
    "candidate_summary",
    "stakes_tier",
    "requirements",
    "missing_evidence",
    "conflicting_evidence",
    "sufficiency_rule",
    "source_independence",
    "confidence_calibration",
    "residual_risk",
    "verdict",
    "allowed_next_actions",
    "blocked_next_actions",
    "fallback_behavior",
    "suggested_wording",
    "next_evidence_actions"
  ],
  "properties": {
    "gate_required": {
      "type": "boolean"
    },
    "gate_reason": {
      "type": "string"
    },
    "candidate_summary": {
      "type": "string"
    },
    "stakes_tier": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "mandatory",
          "acceptable_kinds",
          "status",
          "evidence_refs",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "mandatory": {
            "type": "boolean"
          },
          "acceptable_kinds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "satisfied",
              "missing",
              "conflicting",
              "not_applicable"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conflicting_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sufficiency_rule": {
      "type": "string"
    },
    "source_independence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rating", "rationale"],
      "properties": {
        "rating": {
          "type": "string",
          "enum": ["high", "medium", "low", "not_applicable"]
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "confidence_calibration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "rationale"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["high", "medium", "low", "not_applicable"]
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "residual_risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "severity", "mitigations"],
      "properties": {
        "description": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["none", "low", "medium", "high"]
        },
        "mitigations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "SOFT_PASS", "BLOCK", "CONFLICT", "ESCALATE"]
    },
    "allowed_next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fallback_behavior": {
      "type": "string"
    },
    "suggested_wording": {
      "type": "string"
    },
    "next_evidence_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "gate_required": {
            "const": false
          }
        },
        "required": ["gate_required"]
      },
      "then": {
        "properties": {
          "source_independence": {
            "properties": {
              "rating": {
                "const": "not_applicable"
              }
            }
          },
          "confidence_calibration": {
            "properties": {
              "level": {
                "const": "not_applicable"
              }
            }
          },
          "residual_risk": {
            "properties": {
              "severity": {
                "const": "none"
              },
              "mitigations": {
                "maxItems": 0
              }
            }
          },
          "verdict": {
            "const": "PASS"
          },
          "requirements": {
            "maxItems": 0
          },
          "missing_evidence": {
            "maxItems": 0
          },
          "conflicting_evidence": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verdict": {
            "enum": ["SOFT_PASS", "BLOCK", "CONFLICT", "ESCALATE"]
          }
        },
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "gate_required": {
            "const": true
          }
        }
      }
    }
  ]
}
